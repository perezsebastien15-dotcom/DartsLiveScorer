<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_play"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginEnd="15dp">

        <TextView
            android:id="@+id/num_essai"
            android:layout_width="232dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/neon"
            android:gravity="center_vertical|center_horizontal"
            android:shadowColor="#84000000"

            android:shadowDx="10"
            android:shadowDy="10"
            android:shadowRadius="20"
            android:text="Essai num : 1"
            android:textColor="#08FF00"
            android:textSize="25sp"
            android:textStyle="bold"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginEnd="15dp">

        <TextView
            android:id="@+id/comb_un"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:fontFamily="@font/neon"
            android:gravity="center_vertical|center_horizontal"
            android:layout_marginEnd="10dp"

            android:shadowColor="#000000"
            android:shadowDx="15"
            android:shadowDy="15"
            android:shadowRadius="30"
            android:text="20"
            android:textColor="#00FFEA"
            android:textSize="25sp"
            android:textStyle="bold"
            />
        <TextView
            android:id="@+id/comb_deux"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:fontFamily="@font/neon"
            android:gravity="center_vertical|center_horizontal"
            android:layout_marginEnd="10dp"

            android:shadowColor="#000000"
            android:shadowDx="15"
            android:shadowDy="15"
            android:shadowRadius="30"
            android:text="20"
            android:textColor="#00FFEA"
            android:textSize="25sp"
            android:textStyle="bold"
            />

        <TextView
            android:id="@+id/comb_trois"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:fontFamily="@font/neon"
            android:gravity="center_vertical|center_horizontal"
            android:layout_marginEnd="10dp"

            android:shadowColor="#000000"
            android:shadowDx="15"
            android:shadowDy="15"
            android:shadowRadius="30"
            android:text="20"
            android:textColor="#00FFEA"
            android:textSize="25sp"
            android:textStyle="bold"
            />
        <TextView
            android:id="@+id/comb_quatre"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:fontFamily="@font/neon"
            android:gravity="center_vertical|center_horizontal"

            android:shadowColor="#000000"
            android:shadowDx="15"
            android:shadowDy="15"
            android:shadowRadius="30"
            android:text="20"
            android:textColor="#00FFEA"
            android:textSize="25sp"
            android:textStyle="bold"
            />

    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical|center_horizontal">

        <ImageView
            android:id="@+id/res_un"
            android:layout_width="120px"
            android:layout_height="120px"
            android:layout_marginLeft="10dp"
            android:background="@drawable/custombordercricket" />
        <ImageView
            android:id="@+id/res_deux"
            android:layout_width="120px"
            android:layout_height="120px"
            android:layout_marginLeft="10dp"
            android:background="@drawable/custombordershoot" />
        <ImageView
            android:id="@+id/res_trois"
            android:layout_width="120px"
            android:layout_height="120px"
            android:layout_marginLeft="10dp"
            android:background="@drawable/customborderuth" />
        <ImageView
            android:id="@+id/res_quatre"
            android:layout_width="120px"
            android:layout_height="120px"
            android:layout_marginLeft="10dp"
            android:background="@drawable/custombordermm" />

    </LinearLayout>

</LinearLayout>
