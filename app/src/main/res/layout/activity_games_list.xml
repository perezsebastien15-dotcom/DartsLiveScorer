<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".commonActivities.GamesListActivity"
    android:background="@drawable/wood">

    <TextView
        android:id="@+id/tvJeu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingBottom="10dp"
        android:text="@string/chooseGame"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:shadowColor="#00F7FF"
        android:shadowDx="10"
        android:shadowDy="10"
        android:shadowRadius="30"
        android:textColor="#00FFEA"
        android:textSize="25sp"
        android:textStyle="bold"
        app:fontFamily="@font/bines"/>

    <Button
        android:id="@+id/jeuretour"
        android:layout_width="150dp"
        android:layout_height="30dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="15dp"
        android:background="?android:attr/selectableItemBackground"
        android:gravity="start"
        android:text="@string/retour"
        android:textColor="#FA00F6"
        android:textSize="20sp"
        android:textStyle="bold"
        app:fontFamily="@font/led"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvJeu"
        android:shadowColor="#FA00F6"
        android:shadowDx="10"
        android:shadowDy="10"
        android:shadowRadius="30"/>


    <GridView
        android:id="@+id/game_grid_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numColumns="1"
        app:layout_constraintTop_toBottomOf="@id/jeuretour"
        android:layout_marginTop="30dp"
        tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>