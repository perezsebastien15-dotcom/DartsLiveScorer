<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".gamesActivities.MasterMindActivity"
    android:background="@drawable/metal">

    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_width="match_parent"
        android:layout_height="245px"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="5dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120px"

            android:orientation="horizontal"
            android:background="@drawable/customborderbuttons">

            <TextView
                android:id="@+id/titre_adversaire"
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:text="@string/title_master_mind"
                android:textColor="#08FF00"
                android:textSize="30sp"
                android:textStyle="bold"

                android:shadowColor="#08FF00"
                android:shadowDx="5"
                android:shadowDy="5"
                android:shadowRadius="10"

                android:fontFamily="@font/neon"
                android:gravity="center_vertical|center_horizontal"
                tools:ignore="RtlCompat" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120px"
            android:orientation="horizontal"
            android:gravity="center_vertical|center_horizontal"
            >

            <TextView
                android:id="@+id/nb_tours"
                android:layout_width="232dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/neon"
                android:gravity="center_vertical|center_horizontal"
                android:shadowColor="#84000000"

                android:shadowDx="10"
                android:shadowDy="10"
                android:shadowRadius="20"
                android:text="Tour : 1/20"
                android:textColor="#08FF00"
                android:textSize="25sp"
                android:textStyle="bold"
                tools:ignore="RtlCompat" />

            <TextView
                android:layout_width="240dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"
                android:gravity="center_vertical|center_horizontal"
                android:paddingEnd="10dp"

                android:shadowColor="#00FFEA"
                android:shadowDx="15"
                android:shadowDy="15"
                android:shadowRadius="30"
                android:text="Combinaisons"
                android:textColor="#00FFEA"
                android:textSize="30sp"
                android:textStyle="bold"
                app:fontFamily="@font/neon" />

            <TextView
                android:id="@+id/title_resultat"
                android:layout_width="230dp"
                android:layout_height="120px"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"

                android:clickable="false"
                android:fontFamily="@font/neon"
                android:gravity="center_vertical"
                android:shadowColor="#CDDC39"

                android:shadowDx="5"
                android:shadowDy="5"
                android:shadowRadius="10"
                android:text="Resultats"

                android:textAlignment="center"
                android:textColor="#D9FF00"
                android:textSize="30dp"
                android:textStyle="bold"
                tools:ignore="RtlCompat" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/middleLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/topLayout"
        android:layout_above="@id/bottomLayout">

        <GridView
            android:id="@+id/gridViewTentatives"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:numColumns="1"
            android:scrollbars="vertical" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true">

        <GridLayout
            android:id="@+id/gridLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="9"
            android:rowCount="3" />
    </LinearLayout>

</RelativeLayout>
