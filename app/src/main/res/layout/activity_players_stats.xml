<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".commonActivities.StatsActivity"
    android:background="@drawable/wood">

    <TextView
        android:id="@+id/titre_stat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/stats_joueur"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:shadowColor="#00F7FF"
        android:shadowDx="15"
        android:shadowDy="15"
        android:shadowRadius="30"
        android:textColor="#00FFEA"
        android:textSize="25sp"
        android:textStyle="bold"
        app:fontFamily="@font/bines"/>

    <Button
        android:id="@+id/jeuretour"
        android:layout_width="150dp"
        android:layout_height="30dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="15dp"
        android:background="?android:attr/selectableItemBackground"
        android:gravity="start"
        android:text="@string/retour"
        android:textColor="#FA00F6"
        android:textSize="20sp"
        android:textStyle="bold"
        app:fontFamily="@font/led"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titre_stat"
        android:shadowColor="#FA00F6"
        android:shadowDx="15"
        android:shadowDy="15"
        android:shadowRadius="30"/>

    <LinearLayout
        android:id="@+id/lay_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/titre_stat"
        android:layout_marginTop="100dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/jeuretour"
        android:padding="16dp">

        <EditText
            android:id="@+id/nomEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/nouveauJoueurNom"
            android:textSize="20sp"
            android:shadowColor="#FFF200"
            android:shadowDx="15"
            android:shadowDy="15"
            android:shadowRadius="30"
            android:textColor="#FFF200"
            android:textStyle="bold"
            android:fontFamily="@font/bines"
            />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>